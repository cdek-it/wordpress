{
  "name": "cdek/woocommerce-delivery-integration",
  "description": "CDEK Delivery integration plugin for WooCommerce",
  "type": "wordpress-plugin",
  "license": "GPL-3.0",
  "authors": [
    {
      "name": "Ilya Klementiev",
      "email": "i.klementev@cdek.ru",
      "role": "Creator"
    },
    {
      "name": "George",
      "email": "g.perman@cdek.ru",
      "role": "Maintainer"
    },
    {
      "name": "Arseniy",
      "email": "a.ustiuzhaninov@cdek.ru",
      "role": "Contributor"
    },
    {
      "name": "Darya Polyakova",
      "role": "Supporter"
    },
    {
      "name": "Vika Melnikova",
      "role": "Supporter"
    }
  ],
  "support": {
    "email": "integrator@cdek.ru",
    "docs": "https://github.com/cdek-it/wordpress/wiki",
    "source": "https://github.com/cdek-it/wordpress",
    "issues": "https://github.com/cdek-it/wordpress/issues",
    "forum": "https://github.com/cdek-it/wordpress/discussions"
  },
  "autoload": {
    "psr-4": {
      "Cdek\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Cdek\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^7.4",
    "composer/installers": "~2.0",
    "paragonie/paserk": "^1.1",
    "paragonie/paseto": "^2.4"
  },
  "require-dev": {
    "brain/monkey": "^2",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.2",
    "php-stubs/woocommerce-stubs": "^10.9",
    "phpstan/extension-installer": "^1.4",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^9.6",
    "roave/security-advisories": "dev-latest",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-cli/i18n-command": "^2.5",
    "wp-coding-standards/wpcs": "^3.3"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "phpstan/extension-installer": true
    },
    "platform": {
      "php": "7.4"
    }
  },
  "archive": {
    "exclude": [
      "blueprint",
      ".*",
      "src/Frontend",
      "node_modules",
      "vendor/composer/installers",
      "composer.lock",
      "package.json",
      "yarn.lock",
      "webpack.config.js",
      "sonar-project.properties",
      "guide",
      "tests",
      "phpunit.xml",
      "Taskfile.yml",
      "phpcs.xml",
      "phpstan.neon",
      "phpstan-baseline.neon",
      ".phpstan",
      "bin"
    ]
  },
  "scripts": {
    "dumplang": [
      "vendor/bin/wp --allow-root make-mo lang lang",
      "vendor/bin/wp --allow-root make-json --no-purge lang lang"
    ],
    "test": "phpunit",
    "lint": "bash bin/phpcs-diff.sh",
    "lint-full": "phpcs",
    "stan": "phpstan analyse --memory-limit=512M"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "https://repo-proxy.cdek.tech/repository/php-public"
    },
    {
      "packagist.org": false
    }
  ]
}
